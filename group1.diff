+def find_existing_sphere_rest(
+    *,
+    project_id: str,
+    headers: dict[str, str],
+    name: str,
+) -> str | None:
+    url = f"https://firestore.googleapis.com/v1/projects/{project_id}/databases/(default)/documents:runQuery"
+    query = {
+        "structuredQuery": {
+            "from": [{"collectionId": "spheres"}],
+            "where": {
+                "compositeFilter": {
+                    "op": "AND",
+                    "filters": [
+                        {
+                            "fieldFilter": {
+                                "field": {"fieldPath": "isPremade"},
+                                "op": "EQUAL",
+                                "value": {"booleanValue": True},
+                            }
+                        },
+                        {
+                            "fieldFilter": {
+                                "field": {"fieldPath": "name"},
+                                "op": "EQUAL",
+                                "value": {"stringValue": name},
+                            }
+                        },
+                    ],
+                }
+            },
+            "limit": 1,
+        }
+    }
+    response = requests.post(url, headers=headers, json=query, timeout=60)
+    if response.status_code >= 400:
+        raise RuntimeError(f"Firestore query failed ({response.status_code}): {response.text}")
+    for row in response.json():
+        document = row.get("document")
+        if document:
+            return firestore_document_path(document["name"])
+    return None
+
+
+def member_count_rest(
+    *,
+    project_id: str,
+    headers: dict[str, str],
+    sphere_path: str,
+) -> int:
+    url = f"https://firestore.googleapis.com/v1/projects/{project_id}/databases/(default)/documents/{sphere_path}/members?pageSize=1000"
+    response = requests.get(url, headers=headers, timeout=60)
+    if response.status_code == 404:
+        return 0
+    if response.status_code >= 400:
+        raise RuntimeError(f"Firestore members list failed ({response.status_code}): {response.text}")
+    return len(response.json().get("documents", []))
+
+
+def commit_rest_batch(
+    *,
+    project_id: str,
+    headers: dict[str, str],
+    writes: list[tuple[str, dict[str, Any]]],
+) -> None:
+    url = f"https://firestore.googleapis.com/v1/projects/{project_id}/databases/(default)/documents:batchWrite"
+    for start in range(0, len(writes), 20):
+        payload = {
+            "writes": [
+                {
+                    "update": {
+                        "name": f"projects/{project_id}/databases/(default)/documents/{path}",
+                        "fields": {key: firestore_value(value) for key, value in data.items()},
+                    },
+                    "updateMask": {"fieldPaths": list(data.keys())},
+                }
+                for path, data in writes[start : start + 20]
+            ]
+        }
+        response = requests.post(url, headers=headers, json=payload, timeout=60)
+        if response.status_code >= 400:
+            raise RuntimeError(f"Firestore batchWrite failed ({response.status_code}): {response.text}")
+
+
+def seed_default_spheres_with_gcloud_rest() -> None:
+    project_id = gcloud_project_id()
+    token = run_command(["gcloud", "auth", "print-access-token"])
+    if not token:
+        raise RuntimeError("Could not get gcloud access token. Run: gcloud auth login")
+    headers = {
+        "Authorization": f"Bearer {token}",
+        "Content-Type": "application/json",
+    }
+    now = datetime.now(UTC).replace(microsecond=0)
+
+    total_posts = 0
+    total_reactions = 0
+    for name, metadata in SPHERE_METADATA.items():
+        sphere_path = find_existing_sphere_rest(
+            project_id=project_id,
+            headers=headers,
+            name=name,
+        ) or f"spheres/{sphere_doc_id(name)}"
+        sphere_posts = posts_for_sphere(name)
+        latest_post = min(sphere_posts, key=lambda item: item.minutes_ago)
+        latest_at = now - timedelta(minutes=latest_post.minutes_ago)
+
+        writes: list[tuple[str, dict[str, Any]]] = [
+            (
+                sphere_path,
+                {
+                    "name": name,
+                    "description": metadata["description"],
+                    "memberCount": len(USERS),
+                    "createdAt": now - timedelta(days=14),
+                    "creatorId": SYSTEM_USER_ID,
+                    "isPremade": True,
+                    "pinnedTitle": metadata["pinnedTitle"],
+                    "pinnedBody": metadata["pinnedBody"],
+                    "bannerTemplate": metadata["bannerTemplate"],
+                    "chatSeedVersion": CHAT_SEED_VERSION,
+                    "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+                    "lastActivityText": latest_post.text,
+                    "lastActivityAt": latest_at,
+                },
+            )
+        ]
+
+        for index, user in enumerate(USERS.values()):
+            joined_at = now - timedelta(days=12, hours=index)
+            writes.append(
+                (
+                    f"{sphere_path}/members/{user.uid}",
+                    {
+                        "username": user.username,
+                        "joinedAt": joined_at,
+                        "lastReadAt": latest_at - timedelta(minutes=index + 3),
+                        "lastActiveAt": latest_at - timedelta(minutes=index + 1),
+                        "warningCount": 0,
+                        "role": "member",
+                        "miniMe": user.mini_me(),
+                        "miniMeName": user.username,
+                        "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+                    },
+                )
+            )
+
+        for post in sphere_posts:
+            post_path = f"{sphere_path}/posts/{post.id}"
+            created_at = now - timedelta(minutes=post.minutes_ago)
+            writes.append((post_path, post_payload(post, created_at)))
+            total_posts += 1
+            for emoji, reaction_user_id in reaction_assignments(post):
+                writes.append(
+                    (
+                        f"{post_path}/reactions/{reaction_user_id}",
+                        {
+                            "emoji": emoji,
+                            "userId": reaction_user_id,
+                            "updatedAt": created_at + timedelta(minutes=5),
+                            "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+                        },
+                    )
+                )
+                total_reactions += 1
+
+        commit_rest_batch(project_id=project_id, headers=headers, writes=writes)
+        count = member_count_rest(project_id=project_id, headers=headers, sphere_path=sphere_path)
+        commit_rest_batch(
+            project_id=project_id,
+            headers=headers,
+            writes=[(sphere_path, {"memberCount": count})],
+        )
+
+    print(
+        "Seeded default spheres with "
+        f"{len(USERS)} demo members, {total_posts} posts, and {total_reactions} reactions using gcloud REST."
+    )
+
+
+def seed_default_spheres(*, dry_run: bool = False, auth: str = "firebase-admin") -> None:
+    if dry_run:
+        print(
+            f"Dry run: would seed {len(SPHERE_METADATA)} default spheres, "
+            f"{len(USERS)} demo members, and {len(POSTS)} seeded posts."
+        )
+        for name in SPHERE_METADATA:
+            print(f"  - {name}: {len(posts_for_sphere(name))} posts")
+        return
+
+    if auth == "gcloud-rest":
+        seed_default_spheres_with_gcloud_rest()
+        return
+
+    get_firebase_app()
+    from firebase_admin import firestore
+
+    db = firestore.client()
+    now = datetime.now(UTC).replace(microsecond=0)
+
+    total_posts = 0
+    total_reactions = 0
+    for name, metadata in SPHERE_METADATA.items():
+        existing = find_existing_sphere(db, name)
+        sphere_ref = existing.reference if existing else db.collection("spheres").document(sphere_doc_id(name))
+        sphere_posts = posts_for_sphere(name)
+        latest_post = min(sphere_posts, key=lambda item: item.minutes_ago)
+        latest_at = now - timedelta(minutes=latest_post.minutes_ago)
+
+        sphere_payload = {
+            "name": name,
+            "description": metadata["description"],
+            "memberCount": len(USERS),
+            "createdAt": now - timedelta(days=14),
+            "creatorId": SYSTEM_USER_ID,
+            "isPremade": True,
+            "pinnedTitle": metadata["pinnedTitle"],
+            "pinnedBody": metadata["pinnedBody"],
+            "bannerTemplate": metadata["bannerTemplate"],
+            "chatSeedVersion": CHAT_SEED_VERSION,
+            "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+            "lastActivityText": latest_post.text,
+            "lastActivityAt": latest_at,
+        }
+
+        writes: list[tuple[Any, dict[str, Any]]] = [(sphere_ref, sphere_payload)]
+
+        for index, user in enumerate(USERS.values()):
+            joined_at = now - timedelta(days=12, hours=index)
+            writes.append(
+                (
+                    sphere_ref.collection("members").document(user.uid),
+                    {
+                        "username": user.username,
+                        "joinedAt": joined_at,
+                        "lastReadAt": latest_at - timedelta(minutes=index + 3),
+                        "lastActiveAt": latest_at - timedelta(minutes=index + 1),
+                        "warningCount": 0,
+                        "role": "member",
+                        "miniMe": user.mini_me(),
+                        "miniMeName": user.username,
+                        "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+                    },
+                )
+            )
+
+        for post in sphere_posts:
+            post_ref = sphere_ref.collection("posts").document(post.id)
+            created_at = now - timedelta(minutes=post.minutes_ago)
+            writes.append((post_ref, post_payload(post, created_at)))
+            total_posts += 1
+            for emoji, reaction_user_id in reaction_assignments(post):
+                writes.append(
+                    (
+                        post_ref.collection("reactions").document(reaction_user_id),
+                        {
+                            "emoji": emoji,
+                            "userId": reaction_user_id,
+                            "updatedAt": created_at + timedelta(minutes=5),
+                            "defaultContentSeedVersion": DEFAULT_CONTENT_SEED_VERSION,
+                        },
+                    )
+                )
+                total_reactions += 1
+
+        for start in range(0, len(writes), 450):
+            commit_batch(db, writes[start : start + 450])
+
+        # Keep memberCount aligned with the actual seeded + real member docs.
+        member_count = sum(1 for _ in sphere_ref.collection("members").stream())
+        sphere_ref.set({"memberCount": member_count}, merge=True)
+
+    print(
+        "Seeded default spheres with "
+        f"{len(USERS)} demo members, {total_posts} posts, and {total_reactions} reactions."
+    )
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description="Seed default community sphere activity.")
+    parser.add_argument(
+        "--dry-run",
+        action="store_true",
+        help="Print what would be seeded without writing to Firestore.",
+    )
+    parser.add_argument(
+        "--auth",
+        choices=("firebase-admin", "gcloud-rest"),
+        default="firebase-admin",
+        help="Authentication method to use for Firestore writes.",
+    )
+    args = parser.parse_args()
+    seed_default_spheres(dry_run=args.dry_run, auth=args.auth)
+
+
+if __name__ == "__main__":
+    main()
