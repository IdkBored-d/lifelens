# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

end

post_integrate do |_installer|
  # flutter_gemma 0.12.6 currently resolves TensorFlowLiteSelectTfOps to a
  # device-only XCFramework slice (ios-arm64). Keep it linked for iphoneos,
  # but strip it from simulator linking so iOS simulators can build.
  pods_runner_support = File.join(__dir__, 'Pods', 'Target Support Files', 'Pods-Runner')
  %w[debug release profile].each do |config|
    xcconfig = File.join(pods_runner_support, "Pods-Runner.#{config}.xcconfig")
    next unless File.exist?(xcconfig)

    text = File.read(xcconfig)
    next unless text.include?('TensorFlowLiteSelectTfOps')

    text = text.gsub(' -framework "TensorFlowLiteSelectTfOps"', '')

    if text =~ /^OTHER_LDFLAGS\[sdk=iphoneos\*\]\s*=\s*(.*)$/
      existing = Regexp.last_match(1)
      unless existing.include?('TensorFlowLiteSelectTfOps')
        text = text.sub(
          /^OTHER_LDFLAGS\[sdk=iphoneos\*\]\s*=\s*.*$/,
          "OTHER_LDFLAGS[sdk=iphoneos*] = #{existing} -framework \"TensorFlowLiteSelectTfOps\""
        )
      end
    else
      text << "\nOTHER_LDFLAGS[sdk=iphoneos*] = $(inherited) -framework \"TensorFlowLiteSelectTfOps\"\n"
    end

    File.write(xcconfig, text)
  end
end
