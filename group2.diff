+                                    ),
+                                  ),
+                                  title: Text(sphere.name),
+                                  subtitle: Text(
+                                    '${sphere.memberCount} members • ${sphere.isPublic ? 'Public' : 'Invite only'}',
+                                  ),
+                                  trailing: trailing,
+                                );
+                              },
+                            );
+                          },
+                        ),
+                      ),
+                    ],
+                  ),
+                ),
+              ),
+            );
+          },
+        );
+      },
+    );
+  }
